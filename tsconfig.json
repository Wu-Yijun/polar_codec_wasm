{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": "./dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "lib/**/*",
    "examples/**/*",
    "test/**/*",
    "scripts/**/*"
  ]
}