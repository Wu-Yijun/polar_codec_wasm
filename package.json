{
  "name": "polar_codec_wasm",
  "version": "1.0.1",
  "author": "Aluria",
  "description": "Zero-dependency WebAssembly implementation of Polar Codes (FEC) for Node.js, browsers, and Deno, powered by Rust.",
  "keywords": [
    "polar codes",
    "fec",
    "forward-error-correction",
    "channel-coding",
    "error-correcting codes",
    "5g",
    "crc",
    "wasm",
    "webassembly",
    "rust",
    "typescript",
    "zero-dependency",
    "browser",
    "node"
  ],
  "homepage": "https://github.com/Wu-Yijun/polar_codec_wasm#readme",
  "bugs": {
    "url": "https://github.com/Wu-Yijun/polar_codec_wasm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wu-Yijun/polar_codec_wasm.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "unpkg": "./dist/index.iife.js",
  "jsdelivr": "./dist/index.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.ts",
    "examples": "node ./examples/basic.ts && node ./examples/parameters.ts && node ./examples/noise.ts && node ./examples/performance.ts",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}